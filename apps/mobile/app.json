{
  "expo": {
    "name": "BlockPay",
    "slug": "blockpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.blockpay.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.blockpay.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-notifications"],
    "scheme": "blockpay",
    "extra": {
      "eas": {
        "projectId": "blockpay-mvp"
      }
    }
  }
}
